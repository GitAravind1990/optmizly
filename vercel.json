{
  "crons": [
    {
      "path": "/api/cron/drip",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/trial-reminder",
      "schedule": "0 9 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.optmizly.com"
        }
      ],
      "destination": "https://optmizly.com/:path",
      "permanent": true
    }
  ],
  "functions": {
    "src/app/api/rewrite/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/topical/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/serp/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/tracker/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/local/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/analyse/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/eeat/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/gap/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/citation/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/queries/route.ts": {
      "maxDuration": 30
    }
  }
}